# ============================================================
# Face Recognition Auth System — Environment Configuration
# ============================================================
# Copy this file to .env and fill in secure values.
# NEVER commit .env to version control.
# ============================================================

# --- Application ---
APP_NAME=FaceAuth
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./data/faceauth.db

# --- JWT Authentication ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Encryption (AES-256) ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_ENCRYPTION_KEY=CHANGE_ME_TO_A_FERNET_KEY

# --- Face Recognition ---
FACE_MATCH_THRESHOLD=0.6
FACE_QUALITY_MIN_SCORE=85
FACE_MIN_SIZE=100
LIVENESS_REQUIRED_FRAMES=3

# --- Rate Limiting ---
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_DURATION_MINUTES=30
RATE_LIMIT_PER_MINUTE=100

# --- Session ---
MAX_ACTIVE_SESSIONS=5

# --- Email (optional — set to 'console' for dev) ---
EMAIL_BACKEND=console
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@faceauth.local

# --- CORS ---
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# --- Backup ---
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30
